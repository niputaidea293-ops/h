{
  "manifest_version": 2,
  "name": "BurlonAI Search Bridge",
  "version": "2.0.0",
  "description": "Envía búsquedas detectadas en Firefox a tu panel local BurlonAI.",
  "permissions": [
    "tabs",
    "notifications",
    "storage",
    "*://*.google.com/*",
    "*://duckduckgo.com/*",
    "*://www.bing.com/*",
    "http://127.0.0.1:8787/*"
  ],
  "icons": {
    "128": "icon.svg"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "burlonai@local"
    }
  }
}
